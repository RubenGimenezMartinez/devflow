{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Run DevFlow Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/devflow-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/devflow-extension/dist/**/*.js"
      ],
      "preLaunchTask": "npm: compile - devflow-extension"
    }
  ]
}

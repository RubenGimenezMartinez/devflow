{
  "name": "devflow",
  "displayName": "DevFlow - Jira Workflow Automation",
  "description": "Automatiza flujos de trabajo de Jira con Copilot Chat",
  "version": "0.1.0",
  "publisher": "devflow",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devflow.startFlow",
        "title": "DevFlow: Start Flow from Jira Issue"
      },
      {
        "command": "devflow.openDashboard",
        "title": "DevFlow: Open Dashboard"
      },
      {
        "command": "devflow.configureFlows",
        "title": "DevFlow: Configure Flows"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devflow",
          "title": "DevFlow",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "devflow": [
        {
          "id": "devflow.flows",
          "name": "Flows"
        },
        {
          "id": "devflow.activeFlow",
          "name": "Active Flow"
        }
      ]
    },
    "configuration": {
      "title": "DevFlow",
      "properties": {
        "devflow.jira.baseUrl": {
          "type": "string",
          "description": "Jira instance base URL (e.g., https://your-org.atlassian.net)"
        },
        "devflow.jira.email": {
          "type": "string",
          "description": "Jira account email"
        },
        "devflow.flowsPath": {
          "type": "string",
          "default": "./flows",
          "description": "Path to flow definition files"
        },
        "devflow.knowledgeBasePath": {
          "type": "string",
          "default": "./knowledge-base",
          "description": "Path to knowledge base directory"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "devflow.chat",
        "name": "devflow",
        "fullName": "DevFlow Assistant",
        "description": "Automatiza flujos de Jira",
        "isSticky": false
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "build:webview": "cd webview && npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "yaml": "^2.3.0"
  }
}
